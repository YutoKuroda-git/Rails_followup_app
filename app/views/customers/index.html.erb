<main class="dashboard">

  <section class="dash-head">
    <div>
      <h2 class="dash-title">Followup Dashboard</h2>
      <p class="dash-sub">進行中のタスクを管理します</p>
    </div>

    <div class="dash-actions">
    <%= form_with url: customers_path, method: :get, local: true, class: "search-form" do |f| %>
      <div class="search-input-wrap">
        <span class="material-symbols-outlined search-icon">search</span>
        <%= f.text_field :q, value: params[:q], placeholder: "会社名・顧客名・メールアドレスで検索", class: "search-input" %>
      </div>
      <% if params[:q].present? || params[:status].present? %>
        <%= link_to "クリア", customers_path, class: "search-clear" %>
      <% end %>
    <% end %>

    <%= link_to new_customer_path, class: "btn-add" do %>
      <span class="material-symbols-outlined">add</span>
      <span>新規追加</span>
    <% end %>
  </section>

  <section class="tbl-card">
    <table class="tbl">
      <thead>
        <tr>
          <th>Status</th>
          <th>Name</th>
          <th>Contact</th>
          <th>Due Date</th>
          <th>Last Update</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @customers.each do |customer| %>
          <tr class="tbl-row <%= 'tbl-row--due' if customer.due_soon? %>"data-href="<%= customer_path(customer) %>">
            <td>
              <span class="badge badge-<%= customer.status %>">
                <% labels = { "in_progress" => "対応中", "pending" => "保留", "completed" => "完了" } %>
                <%= labels[customer.status] %>
              </span>
            </td>
            <td>
              <% if customer.company_name.present? %>
                <span class="row-name"><%= customer.company_name %></span>
                <small class="row-sub"><%= customer.contact_name %></small>
              <% else %>
                <span class="row-name"><%= customer.contact_name %></span>
              <% end %>
            </td>
            <td class="td-muted"><%= customer.email.presence || "-" %></td>
            <td class="td-muted">
              <% due = customer.next_due_date %>
              <% if due %>
                <span class="<%= 'td-due-soon' if customer.due_soon? %>">
                  <%= l(due, format: :default) %>
                </span>
              <% else %>
                -
              <% end %>
            </td>
            <td class="td-muted"><%= time_ago_in_words(customer.updated_at) %>前</td>
            <td class="td-action">
              <div class="more-wrap">
                <button class="more-btn" onclick="toggleMore(this)">⋯</button>
                <div class="more-menu">
                  <%= link_to "編集", edit_customer_path(customer), class: "more-item" %>
                  <%= link_to "削除", customer_path(customer), data: { turbo_method: :delete, turbo_confirm: "削除しますか？" }, class: "more-item more-item--del" %>
                </div>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @customers.empty? %>
          <tr>
            <td colspan="6" class="td-empty">顧客データがありません。「新規追加」から登録してください</td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="pagination">
      <span class="pagination-info">
        <%= @customers.offset_value + 1 %>〜<%= [@customers.offset_value + @customers.limit_value, @customers.total_count].min %>件
        （全<%= @customers.total_count %>件）
      </span>
      <%= paginate @customers %>
    </div>
  </section>

  <section class="cards">
    <div class="card">
      <div class="card-top">
        <div class="card-icon icon--progress">
          <span class="material-symbols-outlined">pending_actions</span>
        </div>
        <span class="card-tag tag--progress">In Progress</span>
      </div>
      <div class="card-num">
        <span class="num"><%= @in_progress_count %></span>
        <span class="unit">件</span>
      </div>
      <p class="card-desc">進行中</p>
    </div>

    <div class="card">
      <div class="card-top">
        <div class="card-icon icon--done">
          <span class="material-symbols-outlined">task_alt</span>
        </div>
        <span class="card-tag tag--done">Completed</span>
      </div>
      <div class="card-num">
        <span class="num"><%= @completed_count %></span>
        <span class="unit">件</span>
      </div>
      <p class="card-desc">完了</p>
    </div>

    <div class="card">
      <div class="card-top">
        <div class="card-icon icon--pending">
          <span class="material-symbols-outlined">schedule</span>
        </div>
        <span class="card-tag tag--pending">Pending</span>
      </div>
      <div class="card-num">
        <span class="num"><%= @pending_count %></span>
        <span class="unit">件</span>
      </div>
      <p class="card-desc">保留</p>
    </div>
  </section>

</main>
