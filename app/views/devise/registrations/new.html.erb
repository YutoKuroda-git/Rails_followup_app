<div class="signup-page">

  <div class="signup-header">
    <h1 class="signup-title">Followup</h1>
    <p class="signup-subtitle">Create your account</p>
  </div>

  <div class="signup-card">

    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), local: true, class: "signup-form" do |f| %>

      <div class="form-group">
        <%= f.label :name, "Name", class: "form-label" %>
        <%= f.text_field :name, placeholder: "名前を入力", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <%= f.email_field :email, autocomplete: "email", placeholder: "メールアドレスを入力", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password", class: "form-label" %>

        <div class="form-group">
          <%= f.password_field :password, id: "password-input", autocomplete: "new-password", placeholder: "パスワードを入力", class: "form-input" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
        <%= f.password_field :password_confirmation, placeholder: "確認用パスワードを入力", class: "form-input" %>
      </div>

      <%= f.submit "Create Account", class: "btn-primary" %>

    <% end %>

    <div class="signup-footer">
      <p>Already have an account? <%= link_to "Log in", new_user_session_path, class: "text-link strong" %></p>
    </div>
  </div>

  <footer class="signup-note">
    Secure access for internal users
  </footer>
</div>
